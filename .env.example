# Fabrik secrets configuration
# Copy this file to .env and fill in your GitHub token.
# Make sure .env is listed in .gitignore (Fabrik will refuse to start otherwise).
#
# Non-secret settings (owner, repo, project, user, poll, etc.) belong in
# .fabrik/config.yaml, which is safe to commit to git.
# Run `fabrik init` to generate a .fabrik/config.yaml template.

# Required: GitHub token with repo and project access
FABRIK_TOKEN=ghp_your_token_here
# GITHUB_TOKEN is also accepted for backward compatibility

# Optional: Override the GitHub username for this developer only
# (useful when .fabrik/config.yaml has a team default but you need a different user)
# FABRIK_USER=your-github-username
